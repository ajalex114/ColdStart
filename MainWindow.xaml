<Window x:Class="ColdStart.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ColdStart — Startup Performance Inspector" Height="780" Width="960" MinHeight="500" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}">

    <Grid Margin="24,16,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title row + theme toggle -->
            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="TitleIcon" Text="⚡" FontSize="24" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TitleText" Text="ColdStart" FontSize="20" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Theme toggle — prominent pill button, far right -->
                <Border x:Name="ThemeBorder" Grid.Column="2" VerticalAlignment="Center"
                        Cursor="Hand" CornerRadius="16"
                        BorderThickness="1" Padding="12,6,12,6"
                        MouseLeftButtonUp="ThemeToggle_Click"
                        ToolTip="Toggle theme (Ctrl+T)">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="ThemeIcon" Text="🌙" FontSize="15"
                                   Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="ThemeBtn" Text="Dark" FontSize="12"
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Device info card -->
            <Border x:Name="DeviceInfoCard" Grid.Row="1" CornerRadius="10"
                    Padding="16,10,16,10" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="DeviceInfoIcon" Text="🖥️" FontSize="20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="SystemInfoText" Grid.Column="1" FontSize="12"
                               TextWrapping="Wrap" VerticalAlignment="Center"
                               Text="Loading system info..."/>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══ TABS ═══ -->
        <Border x:Name="TabBarBorder" Grid.Row="1" CornerRadius="10"
                Padding="4" Margin="0,0,0,16" HorizontalAlignment="Left">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="StartupTabBtn" Content="⚡  Startup Analysis" Click="StartupTab_Click"
                        Style="{x:Null}" FontSize="13" FontWeight="Medium" Padding="18,8" Margin="2"
                        BorderThickness="0" Cursor="Hand"
                        ToolTip="Startup Analysis (Ctrl+1)">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button x:Name="TimelineTabBtn" Content="📊  Timeline" Click="TimelineTab_Click"
                        Style="{x:Null}" Background="Transparent"
                        FontSize="13" FontWeight="Medium" Padding="18,8" Margin="2"
                        BorderThickness="0" Cursor="Hand"
                        ToolTip="Startup Timeline (Ctrl+3)">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button x:Name="PerfTabBtn" Content="📈  App Usage" Click="PerfTab_Click"
                        Style="{x:Null}" Background="Transparent"
                        FontSize="13" FontWeight="Medium" Padding="18,8" Margin="2"
                        BorderThickness="0" Cursor="Hand"
                        ToolTip="App Usage (Ctrl+2)">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>

        <!-- ═══ CONTENT ═══ -->
        <Grid Grid.Row="2">
            <!-- Startup Panel -->
            <ScrollViewer x:Name="StartupPanel" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="StartupContent" Margin="0,0,6,0"/>
            </ScrollViewer>

            <!-- Timeline Panel -->
            <ScrollViewer x:Name="TimelinePanel" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled" Visibility="Collapsed">
                <StackPanel x:Name="TimelineContent" Margin="0,0,6,0"/>
            </ScrollViewer>

            <!-- Performance Panel -->
            <ScrollViewer x:Name="PerfPanel" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled" Visibility="Collapsed">
                <StackPanel x:Name="PerfContent" Margin="0,0,6,0"/>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
